{
  "model_class": "bert",
  "tokenizer": "distilbert-base-multilingual-cased",
  "text_name": "shippingAddress",
  "label_name": "__tag__",
  "id_name": "orderDate",
  "tab_field_list": [],
  "cat_field_list": [],
  "full_field_list": [],
  "is_binary": true,
  "num_classes": 2,
  "multiclass_categories": [0, 1],
  "max_sen_len": 128,
  "max_total_chunks": 1,
  "max_epochs": 2,
  "lr": 2e-5,
  "weight_decay": 0.01,
  "optimizer": "AdamW",
  "warmup_steps": 500,
  "batch_size": 64,
  "eval_batch_size_multiplier": 2.0,
  "class_weights": [1.0, 3.0],
  "early_stop_metric": "val/f1_score",
  "early_stop_patience": 2,
  "fp16": true,
  "gradient_clip_val": 1.0,
  "val_check_interval": 1.0,
  "metric_choices": ["auroc", "f1_score"],
  "is_embeddings_trainable": true,
  "reinit_pooler": true,
  "reinit_layers": 2,
  "run_scheduler": true,
  "load_ckpt": false,
  "fixed_tokenizer_length": true
}
