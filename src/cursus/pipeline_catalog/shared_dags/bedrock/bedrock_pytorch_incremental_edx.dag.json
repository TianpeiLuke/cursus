    "agent_context": {
      "when_to_use": "Incremental retraining: you have a prior EDX scored dataset and need to score only NEW addresses via Bedrock LLM, then retrain on the full growing dataset.",
      "when_not_to_use": "First-time training (no EDX baseline exists) \u2014 use pytorch/complete_e2e or bedrock_pytorch_e2e instead.",
      "differentiators": [
        "Only DAG with EDX anti-join (skip already-scored data)",
        "Grows labeled pool incrementally",
        "Requires prior EDX upload to exist"
      ],
      "prerequisites": [
        {
          "check": "EDX scored manifest exists from prior run",
          "how": "Verify EDX ARN accessible via Cradle"
        },
        {
          "check": "Bedrock model access",
          "how": "IAM role has bedrock:InvokeModel for target model"
        },
        {
          "check": "MDS data for new period",
          "how": "Cradle date range covers period NOT in existing EDX"
        }
      ],
      "config_guidance": {
        "user_must_provide": [
          "edx_scored_arn",
          "edx_tags_arn",
          "mds_date_range",
          "bedrock_model_id",
          "author",
          "service_name"
        ],
        "safe_defaults": [
          "batch_size",
          "instance_types",
          "class_weights",
          "train_ratio",
          "max_epochs"
        ],
        "common_pitfalls": [
          "EDX read ARN must point to PREVIOUS batch output, not the one being written (use separate _CRADLE_EDX_END vs _UPLOAD_EDX_END)",
          "MDS date range must NOT overlap scored EDX period \u2014 causes empty anti-join result",
          "pandas str.split(\"|||\") uses regex \u2014 must pass regex=False or use re.escape()",
          "ml.g5.12xlarge ModelInference is NVMe \u2014 VolumeKmsKeyId handled by compiler"
        ]
      },
      "decision_tree": {
        "has_prior_scored_edx?": {
          "yes": "USE THIS DAG",
          "no": "Use full baseline DAG first"
