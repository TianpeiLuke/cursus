    "agent_context": {
      "when_to_use": "Full production pipeline when you need percentile-based calibration (rank-ordering scores into percentile buckets) plus a separate testing path for unbiased evaluation, wiki generation, and model registration. Used by PDA EU/NA, CAP DNR EU projects that need percentile-based risk scores.",
      "when_not_to_use": "If standard isotonic/Platt calibration suffices (use complete_e2e). If you don't need separate testing path (use complete_e2e_with_wiki). If you don't need registration (use training_with_calibration).",
      "differentiators": [
        "PercentileModelCalibration instead of standard ModelCalibration",
        "Three separate data paths: training, calibration, testing",
        "Testing path produces unbiased metrics (no calibration applied)",
        "ModelMetricsComputation + ModelWikiGenerator from testing path",
        "Most comprehensive: 15 nodes, 16 edges"
      ],
      "prerequisites": [
        {
          "check": "Percentile calibration requirements defined",
          "how": "Score bucket boundaries (e.g., P10, P25, P50, P75, P90) agreed with stakeholders"
        },
        {
          "check": "Three separate datasets",
          "how": "Training SQL, calibration SQL, testing SQL from different time periods"
        },
        {
          "check": "MIMS registration access",
          "how": "Service registered in MIMS with valid service_name"
        }
      ],
      "config_guidance": {
        "user_must_provide": [
          "cradle_sql (training)",
          "cradle_sql (calibration)",
          "cradle_sql (testing)",
          "label_column",
          "feature_columns",
          "service_name",
          "author",
          "percentile_buckets"
        ],
        "safe_defaults": [
          "percentile_buckets=[10,25,50,75,90]",
          "instance_type=ml.m5.xlarge",
          "wiki_auto_publish=false"
        ],
        "common_pitfalls": [
          "Testing data must NOT be used in calibration - it provides unbiased evaluation",
          "Percentile calibration is monotonic but not probability-calibrated",
          "Wiki generation may fail if metrics format doesn't match template"
