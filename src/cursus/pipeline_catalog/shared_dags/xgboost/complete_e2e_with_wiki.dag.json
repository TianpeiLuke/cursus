    "agent_context": {
      "when_to_use": "Full production pipeline with model wiki documentation generation. Used when team needs automated model documentation for model review boards or compliance. Includes calibration, metrics computation, wiki generation, and registration.",
      "when_not_to_use": "If you don't need wiki/documentation (use complete_e2e). If you need separate testing path for unbiased metrics (use complete_e2e_with_testing). If you don't need registration (use training_with_calibration).",
      "differentiators": [
        "ModelWikiGenerator produces automated model documentation",
        "ModelMetricsComputation feeds into wiki",
        "Standard (non-percentile) calibration",
        "No separate testing path - metrics from calibration data",
        "13 nodes - lighter than complete_e2e_with_testing (15 nodes)"
      ],
      "prerequisites": [
        {
          "check": "Wiki template defined",
          "how": "Model wiki format agreed with review board"
        },
        {
          "check": "MIMS service registration",
          "how": "Valid service_name for model registration"
        },
        {
          "check": "Calibration dataset available",
          "how": "Separate time period data for calibration and metrics"
        }
      ],
      "config_guidance": {
        "user_must_provide": [
          "cradle_sql (training)",
          "cradle_sql (calibration)",
          "label_column",
          "feature_columns",
          "service_name",
          "author",
          "wiki_metadata"
        ],
        "safe_defaults": [
          "wiki_auto_publish=false",
          "calibration_method=isotonic",
          "instance_type=ml.m5.xlarge"
        ],
        "common_pitfalls": [
          "Wiki metrics come from calibration data, not independent test set",
          "For unbiased metrics reporting, use complete_e2e_with_testing instead",
          "Wiki generation failure does not block registration"
        ]
      },
      "decision_tree": {
        "need_automated_model_docs?": {
