    "agent_context": {
      "when_to_use": "When you have limited labeled data but abundant unlabeled data and want to leverage semi-supervised learning. Uses pretrain->pseudo-label->active-sample->merge->finetune pattern. Used by teams exploring SSL for abuse detection where labeled abuse cases are scarce.",
      "when_not_to_use": "If you have sufficient labeled data (use complete_e2e or training variants). If unlabeled data quality is poor (SSL amplifies noise). If model interpretability is critical (pseudo-labeling adds opacity).",
      "differentiators": [
        "Semi-supervised learning with pseudo-labeling",
        "Two-stage training: pretrain on labeled, finetune on labeled+pseudo",
        "ActiveSampleSelection for confident pseudo-label filtering",
        "PseudoLabelMerge combines original labels with pseudo-labels",
        "Most complex DAG: 16 nodes, 18 edges",
        "Includes calibration, packaging, and registration"
      ],
      "prerequisites": [
        {
          "check": "Limited labeled data",
          "how": "Labeled dataset too small for good supervised performance (<10K labeled samples)"
